{
  "info": {
    "name": "Expense Tracker API",
    "description": "Collection for testing the Expense Tracker REST API. \n\nAlur penggunaan:\n1. Jalankan **Sign Up** untuk membuat akun\n2. Jalankan **Login** - token akan otomatis tersimpan\n3. Semua request Expenses sudah otomatis menggunakan token tersebut",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "expenseId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Secret123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Daftarkan user baru. Password harus minimal 8 karakter, mengandung huruf kapital dan angka."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token saved:', res.token);",
                  "}",
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response has token', () => pm.expect(res.token).to.be.a('string'));",
                  "pm.test('Response has user', () => pm.expect(res.user).to.be.an('object'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Secret123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login dan dapatkan JWT token. Token otomatis tersimpan ke variable `token`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token saved:', res.token);",
                  "}",
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has token', () => pm.expect(res.token).to.be.a('string'));",
                  "pm.test('Response has user', () => pm.expect(res.user).to.be.an('object'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Create Expense",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Makan siang\",\n  \"amount\": 50000,\n  \"category\": \"FOOD\",\n  \"date\": \"2026-03-08\",\n  \"description\": \"Makan di warung nasi padang\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/expenses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses"]
            },
            "description": "Buat expense baru. Category yang valid: FOOD, TRANSPORT, ENTERTAINMENT, HEALTH, UTILITIES, OTHER"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.expense && res.expense.id) {",
                  "  pm.collectionVariables.set('expenseId', res.expense.id);",
                  "  console.log('Expense ID saved:', res.expense.id);",
                  "}",
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response has expense', () => pm.expect(res.expense).to.be.an('object'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get All Expenses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/expenses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses"]
            },
            "description": "Ambil semua expense milik user yang sedang login."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has expenses array', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.expenses).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Expenses - Past Week",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/expenses?filter=past_week",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses"],
              "query": [
                {
                  "key": "filter",
                  "value": "past_week"
                }
              ]
            },
            "description": "Filter expense 7 hari terakhir."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Expenses - Past Month",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/expenses?filter=past_month",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses"],
              "query": [
                {
                  "key": "filter",
                  "value": "past_month"
                }
              ]
            },
            "description": "Filter expense 1 bulan terakhir."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Expenses - Last 3 Months",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/expenses?filter=last_3_months",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses"],
              "query": [
                {
                  "key": "filter",
                  "value": "last_3_months"
                }
              ]
            },
            "description": "Filter expense 3 bulan terakhir."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Expenses - Custom Date Range",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/expenses?filter=custom&startDate=2026-01-01&endDate=2026-03-08",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses"],
              "query": [
                {
                  "key": "filter",
                  "value": "custom"
                },
                {
                  "key": "startDate",
                  "value": "2026-01-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-03-08"
                }
              ]
            },
            "description": "Filter expense dengan rentang tanggal custom. Wajib sertakan startDate dan endDate."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Single Expense",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/expenses/{{expenseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses", "{{expenseId}}"]
            },
            "description": "Ambil detail satu expense berdasarkan ID. Variable `expenseId` otomatis terisi setelah Create Expense."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has expense', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.expense).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Expense",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Makan siang (updated)\",\n  \"amount\": 75000,\n  \"category\": \"FOOD\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/expenses/{{expenseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses", "{{expenseId}}"]
            },
            "description": "Update sebagian atau seluruh field expense. Semua field bersifat opsional (partial update)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has updated expense', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.expense).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete Expense",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/expenses/{{expenseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expenses", "{{expenseId}}"]
            },
            "description": "Hapus expense berdasarkan ID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has success message', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.message).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Cek apakah server berjalan dengan baik."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => {",
              "  const res = pm.response.json();",
              "  pm.expect(res.status).to.equal('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
